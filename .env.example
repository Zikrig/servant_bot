TELEGRAM_BOT_TOKEN=replace_me
TELEGRAM_BOT_USERNAME=your_bot_username

WEBHOOK_PUBLIC_URL=https://your-domain.example
WEBHOOK_SECRET_TOKEN=replace_me_random_string
APP_PORT=8080
AUTO_SET_WEBHOOK=true

DB_PATH=/data/bot.sqlite3
LOG_LEVEL=INFO
MAX_SCENARIOS_PER_USER=20
MAX_SCENARIO_TITLE_LEN=64
MAX_SCENARIO_REPLY_LEN=4000
SCHEDULER_POLL_SECONDS=15
