TELEGRAM_BOT_TOKEN=replace_me

EVOLINK_API_KEY=replace_me
EVOLINK_MODEL_PRIMARY=gpt-5.2
EVOLINK_MODEL_FALLBACK=deepseek-chat
EVOLINK_REQUEST_TIMEOUT_SEC=35
EVOLINK_STRICT_MODEL_VALIDATION=true

WEBHOOK_PUBLIC_URL=https://your-domain.example
WEBHOOK_SECRET_TOKEN=replace_me_random_string
APP_PORT=8080
AUTO_SET_WEBHOOK=true

DB_PATH=/data/bot.sqlite3
LOG_LEVEL=INFO
MAX_SCENARIOS_PER_USER=20
MAX_SCENARIO_TITLE_LEN=64
MAX_SCENARIO_PROMPT_LEN=2000
PROMPT_WRAPPER_FILE=prompts/prompt_wrapper.txt
